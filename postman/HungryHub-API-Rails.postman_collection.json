{
  "info": {
    "_postman_id": "16501811-5d17-4488-83ac-3f2d75fc0e8d",
    "name": "HungryHub API Rails - Assignment Test Collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Postman collection untuk testing endpoint mandatory HungryHub assignment (Rails implementation)."
  },
  "item": [
    {
      "name": "Restaurants",
      "item": [
        {
          "name": "Create Restaurant (POST /restaurants)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-API-Key", "value": "{{apiKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Postman Resto\",\n  \"address\": \"Bangkok\",\n  \"phone\": \"0811111111\",\n  \"opening_hours\": \"09:00-22:00\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/restaurants",
              "host": ["{{baseUrl}}"],
              "path": ["restaurants"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.environment.set('restaurantId', json.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "List Restaurants (GET /restaurants)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-API-Key", "value": "{{apiKey}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/restaurants",
              "host": ["{{baseUrl}}"],
              "path": ["restaurants"]
            }
          }
        },
        {
          "name": "List Restaurants Paginated (GET /restaurants?page=1&per_page=10)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-API-Key", "value": "{{apiKey}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/restaurants?page=1&per_page=10",
              "host": ["{{baseUrl}}"],
              "path": ["restaurants"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "per_page", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Get Restaurant Detail (GET /restaurants/:id)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-API-Key", "value": "{{apiKey}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/restaurants/{{restaurantId}}",
              "host": ["{{baseUrl}}"],
              "path": ["restaurants", "{{restaurantId}}"]
            }
          }
        },
        {
          "name": "Update Restaurant (PUT /restaurants/:id)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-API-Key", "value": "{{apiKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Postman Resto Updated\",\n  \"address\": \"Bangkok Center\",\n  \"opening_hours\": \"10:00-23:00\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/restaurants/{{restaurantId}}",
              "host": ["{{baseUrl}}"],
              "path": ["restaurants", "{{restaurantId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Menu Items",
      "item": [
        {
          "name": "Add Menu Item (POST /restaurants/:id/menu_items)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-API-Key", "value": "{{apiKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Thai Milk Tea\",\n  \"description\": \"Sweet tea\",\n  \"price\": 39.5,\n  \"category\": \"drink\",\n  \"is_available\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/restaurants/{{restaurantId}}/menu_items",
              "host": ["{{baseUrl}}"],
              "path": ["restaurants", "{{restaurantId}}", "menu_items"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.environment.set('menuItemId', json.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "List Menu Items (GET /restaurants/:id/menu_items)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-API-Key", "value": "{{apiKey}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/restaurants/{{restaurantId}}/menu_items",
              "host": ["{{baseUrl}}"],
              "path": ["restaurants", "{{restaurantId}}", "menu_items"]
            }
          }
        },
        {
          "name": "Filter Category (GET /restaurants/:id/menu_items?category=drink)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-API-Key", "value": "{{apiKey}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/restaurants/{{restaurantId}}/menu_items?category=drink",
              "host": ["{{baseUrl}}"],
              "path": ["restaurants", "{{restaurantId}}", "menu_items"],
              "query": [
                { "key": "category", "value": "drink" }
              ]
            }
          }
        },
        {
          "name": "Search + Pagination (GET /restaurants/:id/menu_items?name=tea&page=1&per_page=10)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-API-Key", "value": "{{apiKey}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/restaurants/{{restaurantId}}/menu_items?name=tea&page=1&per_page=10",
              "host": ["{{baseUrl}}"],
              "path": ["restaurants", "{{restaurantId}}", "menu_items"],
              "query": [
                { "key": "name", "value": "tea" },
                { "key": "page", "value": "1" },
                { "key": "per_page", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Update Menu Item (PUT /menu_items/:id)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-API-Key", "value": "{{apiKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Thai Milk Tea Updated\",\n  \"price\": 42.0,\n  \"category\": \"drink\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/menu_items/{{menuItemId}}",
              "host": ["{{baseUrl}}"],
              "path": ["menu_items", "{{menuItemId}}"]
            }
          }
        },
        {
          "name": "Delete Menu Item (DELETE /menu_items/:id)",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "X-API-Key", "value": "{{apiKey}}" }
            ],
