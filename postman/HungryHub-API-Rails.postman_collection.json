              "host": ["{{baseUrl}}"],
              "path": ["menu_items", "{{menuItemId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Cleanup",
      "item": [
        {
          "name": "Delete Restaurant (DELETE /restaurants/:id)",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "X-API-Key", "value": "{{apiKey}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/restaurants/{{restaurantId}}",
              "host": ["{{baseUrl}}"],
              "path": ["restaurants", "{{restaurantId}}"]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "apiKey", "value": "hungryhub-local-key" },
